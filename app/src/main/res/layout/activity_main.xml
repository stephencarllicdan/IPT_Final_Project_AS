<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_img"
        android:scaleType="centerCrop" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_img2"
        android:scaleType="centerCrop"
        android:alpha="0.35" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#70FFFFFF" />

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@color/primary"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Manager"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="210dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Track and manage your service requests"
                android:textColor="#E3F2FD"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="8dp"
            android:layout_margin="12dp"
            android:elevation="4dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search requests..."
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:background="@android:color/transparent"
                android:minHeight="48dp"
                android:padding="10dp" />

            <Button
                android:id="@+id/searchBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textAllCaps="false"
                android:backgroundTint="@color/accent"
                android:textColor="#FFFFFF"
                android:minHeight="48dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <Button
            android:id="@+id/dashboardBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Dashboard"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:backgroundTint="@color/primaryDark"
            android:textColor="#FFFFFF"
            android:minHeight="48dp"
            android:elevation="3dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:elevation="5dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create New Request"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter request title..."
                android:textColor="@color/textPrimary"
                android:background="@drawable/input_bg"
                android:minHeight="48dp"
                android:padding="10dp" />

            <Button
                android:id="@+id/addBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Request"
                android:textAllCaps="false"
                android:backgroundTint="@color/success"
                android:textColor="#FFFFFF"
                android:minHeight="48dp"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Requests"
            android:textColor="@color/textSecondary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="14dp"
            android:layout_marginBottom="6dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="10dp"
            android:paddingBottom="10dp" />

    </LinearLayout>

</FrameLayout>